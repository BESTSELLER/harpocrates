{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "append": {
      "$ref": "#/$defs/append"
    },
    "format": {
      "$ref": "#/$defs/format"
    },
    "output": {
      "type": "string",
      "description": "The destination directory or file for the secrets."
    },
    "owner": {
      "$ref": "#/$defs/owner"
    },
    "prefix": {
      "$ref": "#/$defs/prefix"
    },
    "uppercase": {
      "$ref": "#/$defs/uppercase"
    },
    "secrets": {
      "$ref": "#/$defs/secretsArray",
      "description": "List of secrets to fetch from Vault."
    }
  },
  "required": ["secrets"],
  "$defs": {
    "append": {
      "type": "boolean",
      "description": "Append to the output file instead of overwriting."
    },
    "format": {
      "type": "string",
      "enum": ["env", "json", "secret", "yaml"],
      "description": "The format to output the secrets in."
    },
    "owner": {
      "type": "integer",
      "description": "UID of the owner for the created files."
    },
    "prefix": {
      "type": "string",
      "description": "Prefix to prepend to the output key."
    },
    "uppercase": {
      "type": "boolean",
      "description": "Convert the output key(s) to uppercase."
    },
    "saveAsFile": {
      "type": "boolean",
      "description": "Whether to save the current target as a file."
    },
    "optional": {
      "type": "boolean",
      "description": "Whether to ignore it and continue if the target doesn't exist."
    },
    "secretsArray": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^(?:(\\S| )+\/)*(\\S| )+$"
          },
          {
            "$ref": "#/$defs/secretsObject"
          }
        ]
      }
    },
    "secretsObject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^(?:(\\S| )+\/)*(\\S| )+$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "append": {
              "$ref": "#/$defs/append"
            },
            "format": {
              "$ref": "#/$defs/format"
            },
            "owner": {
              "$ref": "#/$defs/owner"
            },
            "filename": {
              "type": "string",
              "description": "The name of the file to save this secret as."
            },
            "prefix": {
              "$ref": "#/$defs/prefix"
            },
            "saveAsFile": {
              "$ref": "#/$defs/saveAsFile"
            },
            "optional": {
              "$ref": "#/$defs/optional"
            },
            "fileName": {
              "type": "string",
              "description": "An alias for filename."
            },
            "keys": {
              "type": "array",
              "description": "Specific keys to extract from this secret.",
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "patternProperties": {
                      "^(?:(\\S| )+\/)*(\\S| )+$": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "append": {
                            "$ref": "#/$defs/append"
                          },
                          "prefix": {
                            "$ref": "#/$defs/prefix"
                          },
                          "saveAsFile": {
                            "$ref": "#/$defs/saveAsFile"
                          },
                          "alias": {
                            "type": "string",
                            "description": "An alias to rename this key in the output."
                          },
                          "optional": {
                            "$ref": "#/$defs/optional"
                          },
                          "uppercase": {
                            "$ref": "#/$defs/uppercase"
                          }
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
